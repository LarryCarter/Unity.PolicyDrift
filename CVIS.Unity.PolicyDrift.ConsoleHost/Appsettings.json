{
  "ConnectionStrings": {
    "DefaultConnection": "Server=THOUSANDSUNNY;Database=EPV_REPORTING;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/CVIS_Drift_Log_.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Governance": {
    "RequireSnowTicket": false,
    "DriftScope": {
      "XML": true,
      "DLL": true,
      "EXE": false
    }
  },
  "Monitoring": {
    "PolicyBaselineFolder": "C:\\CVIS\\PolicyDrift\\BaselineUpdate",
    "PolicyEvalFolder": "C:\\CVIS\\PolicyDrift\\PolicyEval"
  },
  "Kafka": {
    "C": "\\CVIS\\PolicyDrift\\BaselineUpdate\\PolicyDrift\\PolicyEval\\",
    "BootstrapServers": "your-kafka-broker:9092",
    "DriftTopic": "unity.policy.drift.events",
    "StatusTopic": "unity.policy.batch.status"
  }
}