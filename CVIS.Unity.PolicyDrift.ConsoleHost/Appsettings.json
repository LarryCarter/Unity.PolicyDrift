{
  "ConnectionStrings": {
    "DefaultConnection": "Server=THOUSANDSUNNY;Database=EPV_REPORTING;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/CVIS_Drift_Log_.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "Storage": {
    "BaselinePath": "C:\\CVIS\\PolicyDrift\\BaselineUpdates",
    "ZipDownloadTemp": "C:\\CVIS\\PolicyDrift\\PolicyEval"
  },
  "Monitoring": {
    "WorkingFolder": "C:\\CVIS\\PolicyDrift\\BaselineUpdate",
    "UpdatePolicyFolder": "C:\\CVIS\\PolicyDrift\\PolicyEval"
  },
  "Kafka": {
    "BootstrapServers": "your-kafka-broker:9092",
    "DriftTopic": "unity.policy.drift.events",
    "StatusTopic": "unity.policy.batch.status"
  }
}